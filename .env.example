# Copy this file to .env (or .env.local) and fill in real values. Never commit it.
# Read by Next.js at build/runtime — no separate wiring step needed.

# Formspree — powers the contact & booking forms, relayed server-side via
# app/api/contact and app/api/booking (never exposed to the browser).
FORMSPREE_FORM_ID=

# Sanity CMS — powers the blog (fetched in Server Components, see lib/sanity.js).
# Also needed as real Vercel project env vars for the production build/ISR.
SANITY_PROJECT_ID=
SANITY_DATASET=production
# Write access, used only by `npm run seed` (scripts/seed-sanity.mjs) — never needed in Vercel.
SANITY_WRITE_TOKEN=

# Google Analytics — visitor tracking. Must be NEXT_PUBLIC_-prefixed because
# components/GoogleAnalytics.jsx reads it in the browser. Leave blank to omit.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# reCAPTCHA v2 checkbox — client-side bot deterrent on the contact/booking forms,
# in addition to the honeypot field. NEXT_PUBLIC_RECAPTCHA_SITE_KEY renders the
# widget in the browser; RECAPTCHA_SECRET_KEY is used server-side in
# app/api/contact and app/api/booking to actually verify the token with Google
# before relaying to Formspree. Leave both blank to omit reCAPTCHA entirely.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
