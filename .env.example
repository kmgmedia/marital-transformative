# Copy this file to .env and fill in real values. Never commit .env itself.

# Formspree — powers the contact & booking forms (js/main.js)
FORMSPREE_FORM_ID=

# Sanity CMS — powers the blog (fetched at Eleventy build time, see _data/posts.js)
SANITY_PROJECT_ID=
SANITY_DATASET=production
# Write access, used only by scripts/seed-sanity.mjs — never needed in Vercel.
SANITY_WRITE_TOKEN=

# Google Analytics — visitor tracking
GA_MEASUREMENT_ID=

# reCAPTCHA — spam protection for contact/booking forms (beyond the honeypot field)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
